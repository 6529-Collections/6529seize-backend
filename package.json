{
  "name": "6529backend",
  "version": "1.0.0",
  "main": "backend.js",
  "scripts": {
    "preinstall": "node scripts/enforce-package-manager.cjs",
    "guard:no-package-lock": "node scripts/assert-no-package-lock.cjs",
    "install:secure": "node scripts/require-6529-command.cjs && node scripts/assert-no-package-lock.cjs && node scripts/run-secure-pnpm.cjs install --no-frozen-lockfile",
    "install:secure:frozen": "node scripts/require-6529-command.cjs && node scripts/assert-no-package-lock.cjs && node scripts/run-secure-pnpm.cjs install --frozen-lockfile",
    "install:secure:prod": "node scripts/require-6529-command.cjs && node scripts/assert-no-package-lock.cjs && node scripts/run-secure-pnpm.cjs install --frozen-lockfile --prod",
    "backend:local": "node scripts/require-6529-command.cjs && NODE_ENV=local nodemon src/backend.ts",
    "api:local": "node scripts/require-6529-command.cjs && cd src/api-serverless && NODE_ENV=local nodemon",
    "backend:dev": "node scripts/require-6529-command.cjs && NODE_ENV=development node build/backend.js",
    "api:dev": "node scripts/require-6529-command.cjs && NODE_ENV=development node src/api-serverless/dist/index.js",
    "backend:prod": "node scripts/require-6529-command.cjs && NODE_ENV=production node build/backend.js",
    "generate:deploy-config": "node scripts/require-6529-command.cjs && node scripts/generate-deploy-config.mjs",
    "api:restructure-openapi": "node scripts/require-6529-command.cjs && ./bin/pnpm --filter ./src/api-serverless run restructure-openapi",
    "api:generate-openapi": "node scripts/require-6529-command.cjs && ./bin/pnpm --filter ./src/api-serverless run generate",
    "api:regen-openapi": "node scripts/require-6529-command.cjs && ./bin/pnpm --filter ./src/api-serverless run restructure-openapi && ./bin/pnpm --filter ./src/api-serverless run generate",
    "build:api": "node scripts/require-6529-command.cjs && ./bin/pnpm --filter ./src/api-serverless run build",
    "build:services": "node scripts/require-6529-command.cjs && node scripts/build-services.cjs",
    "build:service": "node scripts/require-6529-command.cjs && node scripts/run-service-script.cjs build",
    "deploy:service": "node scripts/require-6529-command.cjs && node scripts/run-service-script.cjs deploy",
    "prebuild": "node scripts/require-6529-command.cjs && node scripts/generate-deploy-config.mjs",
    "build": "node scripts/require-6529-command.cjs && node scripts/remove-paths.cjs ./build && jest && NODE_OPTIONS=--max-old-space-size=8192 tsc -p tsconfig.json",
    "postbuild": "cp src/teamLoop/team.csv build/teamLoop && cp src/rememesLoop/rememes.csv build/rememesLoop",
    "migrate:new": "node scripts/require-6529-command.cjs && db-migrate -e local create",
    "migrate-local:up": "node scripts/require-6529-command.cjs && db-migrate -e local up",
    "migrate-local:down": "node scripts/require-6529-command.cjs && db-migrate -e local down",
    "migrate:up": "node scripts/require-6529-command.cjs && db-migrate -e main up",
    "migrate:down": "node scripts/require-6529-command.cjs && db-migrate -e main down",
    "tsc": "node scripts/require-6529-command.cjs && tsc",
    "pretest": "node scripts/require-6529-command.cjs && node scripts/generate-deploy-config.mjs",
    "test": "node scripts/require-6529-command.cjs && jest",
    "format": "node scripts/require-6529-command.cjs && prettier --write \"src/**/*.ts\"",
    "prelint": "node scripts/require-6529-command.cjs && node scripts/generate-deploy-config.mjs",
    "lint": "node scripts/require-6529-command.cjs && NODE_OPTIONS=--max-old-space-size=8192 eslint \"src/**/*.ts\" --max-warnings=0",
    "lint:fix": "node scripts/require-6529-command.cjs && NODE_OPTIONS=--max-old-space-size=8192 eslint \"src/**/*.ts\" --fix --max-warnings=0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
