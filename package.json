    "@types/multer": "^2.0.0",
    "@wagmi/chains": "^1.8.0",
    "alchemy-sdk": "^3.6.5",
    "arweave": "^1.11.6",
    "axios": "^1.15.0",
    "axios-retry": "^4.5.0",
    "bignumber.js": "^9.1.1",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.5",
