    "ethereum-block-by-date": "^1.4.9",
    "ethers": "^6.16.0",
    "express": "^4.22.1",
    "firebase-admin": "^13.8.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^6.2.0",
    "image-size": "^2.0.2",
    "imagescript": "^1.3.1",
    "joi": "^17.11.0",
    "json-2-csv": "^3.18.0",
    "memory-cache": "^0.2.0",
    "merkletreejs": "^0.6.0",
    "moment-timezone": "^0.5.45",
    "mp4box": "^2.3.0",
    "mysql": "^2.18.1",
    "node-cron": "^3.0.2",
    "node-emoji": "^2.2.0",
    "node-fetch": "^2.7.0",
    "openai": "^4.24.1",
    "p-limit": "^3.1.0",
    "passport": "^0.7.0",
    "passport-anonymous": "^1.0.1",
    "passport-jwt": "^4.0.1",
    "redis": "^4.7.0",
    "sharp": "^0.34.5",
    "short-uuid": "^4.2.2",
    "slugify": "^1.6.6",
    "winston": "^3.11.0"
  },
  "packageManager": "pnpm@10.33.0"
}
