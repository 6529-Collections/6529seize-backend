    "serverless": "^3.40.0",
    "serverless-offline": "^13.9.0",
    "testcontainers": "^11.0.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.28",
    "typescript": "^5.0.4",
    "typescript-eslint": "^8.32.1"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.980.0",
    "@aws-sdk/client-bedrock-runtime": "^3.980.0",
    "@aws-sdk/client-cloudfront": "^3.980.0",
    "@aws-sdk/client-mediaconvert": "^3.980.0",
    "@aws-sdk/client-s3": "^3.980.0",
    "@aws-sdk/client-secrets-manager": "^3.980.0",
    "@aws-sdk/client-sns": "^3.980.0",
    "@aws-sdk/client-sqs": "^3.980.0",
    "@aws-sdk/s3-request-presigner": "^3.980.0",
    "@emoji-mart/data": "^1.2.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@sentry/serverless": "^7.120.4",
