    "@types/passport-jwt": "^3.0.10",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "fast-check": "^3.17.0",
    "globals": "^16.2.0",
    "jest": "^30.3.0",
    "jest-when": "^3.6.0",
    "db-migrate": "^0.11.14",
