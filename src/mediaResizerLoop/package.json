{
  "name": "mediaresizerloop",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "prebuild": "node ../../scripts/require-6529-command.cjs && node ../../scripts/remove-paths.cjs dist .6529-deploy-package ../../.6529-deploy-packages/mediaResizerLoop && mkdir -p dist",
    "build": "node ../../scripts/prepare-workspace-package.cjs ../../.6529-deploy-packages/mediaResizerLoop && esbuild --external:sharp index.ts --bundle --sourcemap --platform=node --target=es2020 --outfile=dist/index.js",
    "postbuild": "cp -r ../../.6529-deploy-packages/mediaResizerLoop/node_modules dist/ && cp ../../.6529-deploy-packages/mediaResizerLoop/package.json dist/package.json && cd dist && zip -rq index.zip index.js index.js.map node_modules package.json && node ../../scripts/remove-paths.cjs node_modules package.json && cd .. && node ../../scripts/remove-paths.cjs ../../.6529-deploy-packages/mediaResizerLoop",
    "sls-deploy:prod": "node ../../scripts/require-6529-command.cjs && node ../../node_modules/serverless/bin/serverless.js deploy --stage=prod --region=us-east-1",
    "sls-deploy:staging": "node ../../scripts/require-6529-command.cjs && node ../../node_modules/serverless/bin/serverless.js deploy --stage=staging --region=eu-west-1",
    "preinstall": "node ../../scripts/enforce-package-manager.cjs"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "esbuild": "^0.27.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.980.0",
    "@aws-sdk/lib-storage": "^3.980.0"
  },
  "packageManager": "pnpm@10.33.0"
}
