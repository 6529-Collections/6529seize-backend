{
  "name": "nftlinkmediapreviewloop",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "prebuild": "rm -rf dist && mkdir -p dist && rm -rf node_modules",
    "build": "npm i --arch=arm64 --platform=linux --include=optional && ../../node_modules/.bin/esbuild index.ts --bundle --external:sharp --sourcemap --platform=node --target=es2020 --outfile=dist/index.js",
    "postbuild": "cp -r node_modules dist/ && cp package.json dist/ && cd dist && zip -rq index.zip index.js index.js.map node_modules package.json && rm -rf node_modules package.json && cd ..",
    "sls-deploy:prod": "node ../../node_modules/serverless/bin/serverless.js deploy --stage=prod --region=us-east-1",
    "sls-deploy:staging": "node ../../node_modules/serverless/bin/serverless.js deploy --stage=staging --region=eu-west-1"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.110",
    "esbuild": "^0.27.2"
  }
}
