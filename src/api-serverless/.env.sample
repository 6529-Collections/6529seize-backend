# DATABASE SETTINGS
DB_HOST_READ=
DB_USER_READ=
DB_PASS_READ=
DB_PORT=
DB_NAME=

# RATE LIMITING (Optional - defaults shown)
# Enable/disable rate limiting (default: disabled, set to 'true' to enable - also requires Redis)
API_RATE_LIMIT_ENABLED=
# Authenticated users: burst limit (requests per second, default: 30)
API_RATE_LIMIT_AUTH_BURST=
# Authenticated users: sustained rate (requests per second over window, default: 10)
API_RATE_LIMIT_AUTH_SUSTAINED_RPS=
# Authenticated users: sustained window in seconds (default: 60)
API_RATE_LIMIT_AUTH_SUSTAINED_WINDOW_SECONDS=
# Unauthenticated users: burst limit (requests per second, default: 20)
API_RATE_LIMIT_UNAUTH_BURST=
# Unauthenticated users: sustained rate (requests per second over window, default: 5)
API_RATE_LIMIT_UNAUTH_SUSTAINED_RPS=
# Unauthenticated users: sustained window in seconds (default: 60)
API_RATE_LIMIT_UNAUTH_SUSTAINED_WINDOW_SECONDS=
# Internal SSR requests (required for SSR rate limit bypass)
API_RATE_LIMIT_INTERNAL_ID=
API_RATE_LIMIT_INTERNAL_SECRET=

# REDIS (Optional)
REDIS_URL=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_TLS=
FORCE_AVOID_REDIS=

# EXTERNAL APIs (Required for specific features)
# Required for drop signature verification and auth routes
ALCHEMY_API_KEY=
# Optional
RAPID_API_KEY=

# API SETTINGS (Optional)
API_PASSWORD=
ACTIVATE_API_PASSWORD=
SLOW_API_REQUEST_THRESHOLD=
API_LOAD_SECRETS=

# AUTH V2 ROLLOUT (Optional)
# Dedicated secret for hashing session cookies, native refresh tokens, and
# connection share codes. Falls back to JWT_SECRET if unset.
AUTH_SESSION_HASH_SECRET=
# Enables web/native connection-sharing endpoints when true.
AUTH_CONNECTION_SHARING_ENABLED=false
# Rejects legacy/unstructured wallet signatures when true. Keep false until all
# deployed clients are verified with structured signatures.
AUTH_STRUCTURED_SIGNATURES_REQUIRED=false
# Optional global v1-auth migration deadline returned by /api/settings.auth.
# Leave unset for a silent backend release. Example: 2026-07-01T00:00:00.000Z
SESSION_V2_MIGRATION_DEADLINE=
# Allows older websocket clients to authenticate with ?token=. Keep enabled
# until web/mobile have moved to the non-query-token path.
AUTH_LEGACY_WS_QUERY_TOKEN_ENABLED=true

# MEMES MINTING ADMINS (Optional, comma-separated wallet addresses)
DISTRIBUTION_ADMIN_WALLETS=
CLAIMS_ADMIN_WALLETS=

# CLAIMS MEDIA ARWEAVE UPLOADER (Optional)
CLAIMS_MEDIA_ARWEAVE_UPLOAD_SQS_URL=
CLAIMS_MEDIA_ARWEAVE_UPLOAD_DEACTIVATED=

# ATTACHMENTS (Required for attachments feature)
ATTACHMENTS_INGEST_S3_BUCKET=

# AWS (Required for identities service)
AWS_6529_IMAGES_BUCKET_NAME=
