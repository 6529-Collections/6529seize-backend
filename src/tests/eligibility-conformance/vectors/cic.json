[
  {
    "name": "cic-total-received-boundary",
    "dimension": "cic",
    "description": "Total received CIC compares the identity's aggregate cic (sum over all raters, negatives included) with inclusive bounds (spec §6).",
    "identities": [
      { "id": "subject", "cic": 7 },
      { "id": "alice" },
      { "id": "bob" }
    ],
    "subject": "subject",
    "ratings": [
      { "rater": "alice", "target": "subject", "matter": "CIC", "rating": 10 },
      { "rater": "bob", "target": "subject", "matter": "CIC", "rating": -3 }
    ],
    "groups": [
      { "id": "g-min-7", "cic_min": 7 },
      { "id": "g-min-8", "cic_min": 8 }
    ],
    "expected": { "eligible_group_ids": ["g-min-7"] }
  },
  {
    "name": "cic-total-received-negative-window",
