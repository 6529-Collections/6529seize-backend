[
  {
    "name": "nft-collection-flag-only",
    "dimension": "nft",
    "description": "A truthy owns-flag with no token list requires owning at least one token of that collection (spec §7.1).",
    "identities": [{ "id": "subject" }],
    "subject": "subject",
    "nft_ownings": [
      { "owner": "subject", "collection": "memes", "token_id": "100" }
    ],
    "groups": [
      { "id": "g-owns-meme", "owns_meme": true },
      { "id": "g-owns-gradient", "owns_gradient": true }
    ],
    "expected": { "eligible_group_ids": ["g-owns-meme"] }
  },
  {
    "name": "nft-empty-ownings-never-eligible",
    "dimension": "nft",
    "description": "Owning zero tokens of the flagged collection fails the criterion regardless of the match mode or token list (spec §7.1 rule 1).",
    "identities": [{ "id": "subject" }],
    "subject": "subject",
    "groups": [
      {
        "id": "g-any-mode",
        "owns_meme": true,
        "owns_meme_tokens": ["100"],
        "owns_meme_tokens_match_mode": "ANY_TOKEN"
      },
      {
        "id": "g-all-mode",
        "owns_meme": true,
        "owns_meme_tokens": ["100"],
        "owns_meme_tokens_match_mode": "ALL_TOKENS"
      },
      { "id": "g-flag-only", "owns_meme": true }
    ],
    "expected": { "eligible_group_ids": [] }
  },
  {
    "name": "nft-all-tokens-full-set",
    "dimension": "nft",
    "description": "ALL_TOKENS (the default match mode) requires owning every listed token (spec §7.2).",
    "identities": [{ "id": "subject" }],
    "subject": "subject",
    "nft_ownings": [
      { "owner": "subject", "collection": "memes", "token_id": "100" },
      { "owner": "subject", "collection": "memes", "token_id": "201" },
      { "owner": "subject", "collection": "memes", "token_id": "325" }
    ],
    "groups": [
      {
        "id": "g-all-owned",
        "owns_meme": true,
        "owns_meme_tokens": ["100", "201", "325"],
        "owns_meme_tokens_match_mode": "ALL_TOKENS"
      },
      {
        "id": "g-one-missing",
        "owns_meme": true,
        "owns_meme_tokens": ["100", "201", "325", "999"],
        "owns_meme_tokens_match_mode": "ALL_TOKENS"
      }
    ],
    "expected": { "eligible_group_ids": ["g-all-owned"] }
  },
  {
