  {
    "name": "nft-all-tokens-duplicate-list-divergence",
    "dimension": "nft",
    "description": "Degenerate ALL_TOKENS list with a duplicated token id: spec uses set semantics (owning the token suffices); SQL counts JSON rows including duplicates and can never be satisfied.",
    "identities": [{ "id": "subject" }],
    "subject": "subject",
    "nft_ownings": [
      { "owner": "subject", "collection": "memes", "token_id": "100" }
    ],
    "groups": [
      {
        "id": "g-duplicate-list",
        "owns_meme": true,
        "owns_meme_tokens": ["100", "100"],
        "owns_meme_tokens_match_mode": "ALL_TOKENS"
      }
    ],
    "expected": { "eligible_group_ids": ["g-duplicate-list"] },
    "known_divergence": {
      "sql": [
        {
          "group_id": "g-duplicate-list",
          "sql_eligible": false,
          "divergence": "D-8",
          "note": "SQL HAVING compares 1 distinct owned token against 2 JSON list rows; spec treats the list as a set (eligibility-spec.md §7.2, §12 D-8)"
        }
      ]
    }
  },
