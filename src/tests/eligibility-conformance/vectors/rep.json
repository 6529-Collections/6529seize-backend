  {
    "name": "rep-by-user-nonzero-required",
    "dimension": "rep",
    "description": "By-user rep with both bounds null requires a non-zero total from that user (spec §1.2, §5.2); engines agree in the single-category case.",
    "identities": [
      { "id": "subject", "rep": 5 },
      { "id": "alice" },
      { "id": "bob" }
    ],
    "subject": "subject",
    "ratings": [
      {
        "rater": "alice",
        "target": "subject",
        "matter": "REP",
        "category": "artist",
        "rating": 5
      }
    ],
    "groups": [
      { "id": "g-alice-nobounds", "rep_user": "alice" },
      { "id": "g-bob-nobounds", "rep_user": "bob" }
    ],
    "expected": { "eligible_group_ids": ["g-alice-nobounds"] }
  },
